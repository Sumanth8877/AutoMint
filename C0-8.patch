diff --git a/src/lib/services/qstash.service.ts b/src/lib/services/qstash.service.ts
--- a/src/lib/services/qstash.service.ts
+++ b/src/lib/services/qstash.service.ts
@@ -92,18 +92,32 @@ export function verifyQStashSignature(headers: Headers, rawBody: string) {
   const now = Math.floor(Date.now() / 1000);
   const bodyHash = crypto.createHash('sha256').update(rawBody).digest('base64url');
 
+  // C-7 fix: resolve expected webhook URL once for sub claim validation.
+  // Gracefully skips sub check if APP_URL / VERCEL_URL is not determinable.
+  let expectedWebhookUrl: string | null = null;
+  try {
+    expectedWebhookUrl = getWebhookUrl();
+  } catch {
+    expectedWebhookUrl = null;
+  }
+
   for (const key of keys) {
     const payload = verifyJwtSignature(signature, key);
     if (!payload) continue;
     if (payload.exp && payload.exp < now) continue;
     if (payload.nbf && payload.nbf > now) continue;
     if (payload.body && payload.body !== bodyHash) continue;
+    // C-7 fix: validate sub claim — must match our own webhook URL.
+    // Prevents a valid QStash JWT addressed to a different endpoint
+    // from being replayed against this webhook.
+    if (payload.sub && expectedWebhookUrl && payload.sub !== expectedWebhookUrl) continue;
     return payload;
   }
 
   throw new Error('Invalid QStash signature');
 }

diff --git a/src/middleware.ts b/src/middleware.ts
new file mode 100644
--- /dev/null
+++ b/src/middleware.ts
@@ -0,0 +1,30 @@
+// C-8 fix: Centralised Clerk authentication via Next.js edge middleware.
+//
+// Previously: auth enforced per-route by manually calling requireApiUser().
+//             One missed call = publicly accessible endpoint.
+// Now:        Clerk middleware runs at the edge BEFORE any route handler executes.
+//             Every route is protected by default. Public routes explicitly opted out.
+//
+// Public routes (no Clerk auth — these use their own verification):
+//   /sign-in, /sign-up        → Clerk auth pages
+//   /api/webhooks/*           → Alchemy + QStash use signature verification
+//   /api/telegram/webhook     → uses TELEGRAM_WEBHOOK_SECRET timing-safe check
+
+import { clerkMiddleware, createRouteMatcher } from '@clerk/nextjs/server';
+
+const isPublicRoute = createRouteMatcher([
+  '/sign-in(.*)',
+  '/sign-up(.*)',
+  '/api/webhooks/(.*)',
+  '/api/telegram/webhook',
+]);
+
+export default clerkMiddleware(async (auth, request) => {
+  if (!isPublicRoute(request)) {
+    await auth.protect();
+  }
+});
+
+export const config = {
+  matcher: [
+    '/((?!_next|[^?]*\\.(?:html?|css|js(?!on)|jpe?g|webp|png|gif|svg|ttf|woff2?|ico|csv|docx?|xlsx?|zip|webmanifest)).*)',
+    '/(api|trpc)(.*)',
+  ],
+};